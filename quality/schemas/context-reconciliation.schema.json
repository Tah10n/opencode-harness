{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Tah10n/opencode-harness/quality/schemas/context-reconciliation.schema.json",
  "title": "Final Blast-Radius Reconciliation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reconciliation_id",
    "session_key",
    "run_id",
    "task_id",
    "risk_class",
    "strategy_id",
    "context_decision_id",
    "context_decision_fingerprint",
    "context_report_id",
    "context_report_fingerprint",
    "impact_graph_id",
    "impact_graph_fingerprint",
    "pre_workspace_fingerprint",
    "final_workspace_fingerprint",
    "final_diff_fingerprint",
    "evidence_mode",
    "graph_completeness",
    "post_architecture_evidence_fingerprint",
    "reviewer_evidence_fingerprint",
    "changed_paths",
    "verified_post_mutation_test_obligation_ids",
    "unexpected_public_contracts",
    "unexpected_dependency_directions",
    "unexpected_side_effect_edges",
    "unrelated_paths",
    "unplanned_items",
    "status",
    "reason_codes",
    "invalidates_context_decision",
    "reconciled_at",
    "fingerprint"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "reconciliation_id": { "type": "string", "pattern": "^CTXREC-[A-Za-z0-9._-]{0,120}[A-Za-z0-9_-]$" },
    "session_key": { "$ref": "#/$defs/boundedId" },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "task_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "risk_class": { "enum": ["standard-lite", "high", "critical"] },
    "strategy_id": { "enum": ["standard-lite-local-v1", "high-wide-deep-v1", "critical-wide-deep-v1"] },
    "context_decision_id": { "$ref": "#/$defs/boundedId" },
    "context_decision_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "context_report_id": { "anyOf": [{ "$ref": "#/$defs/boundedId" }, { "type": "null" }] },
    "context_report_fingerprint": { "anyOf": [{ "$ref": "#/$defs/fingerprint" }, { "type": "null" }] },
    "impact_graph_id": { "anyOf": [{ "$ref": "#/$defs/boundedId" }, { "type": "null" }] },
    "impact_graph_fingerprint": { "anyOf": [{ "$ref": "#/$defs/fingerprint" }, { "type": "null" }] },
    "pre_workspace_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "final_workspace_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "final_diff_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "evidence_mode": { "enum": ["extractor_grounded", "reviewer_grounded"] },
    "graph_completeness": { "enum": ["complete", "incomplete", "not_claimed"] },
    "post_architecture_evidence_fingerprint": { "anyOf": [{ "$ref": "#/$defs/fingerprint" }, { "type": "null" }] },
    "reviewer_evidence_fingerprint": { "anyOf": [{ "$ref": "#/$defs/fingerprint" }, { "type": "null" }] },
    "changed_paths": { "type": "array", "maxItems": 256, "items": { "$ref": "#/$defs/changedPath" } },
    "verified_post_mutation_test_obligation_ids": { "$ref": "#/$defs/verifiedTestIdArray" },
    "unexpected_public_contracts": { "$ref": "#/$defs/messageArray" },
    "unexpected_dependency_directions": { "$ref": "#/$defs/messageArray" },
    "unexpected_side_effect_edges": { "$ref": "#/$defs/messageArray" },
    "unrelated_paths": { "$ref": "#/$defs/pathArray" },
    "unplanned_items": { "type": "array", "maxItems": 128, "items": { "$ref": "#/$defs/unplannedItem" } },
    "status": { "enum": ["passed", "blocked"] },
    "reason_codes": { "$ref": "#/$defs/reasonCodeArray" },
    "invalidates_context_decision": { "type": "boolean" },
    "reconciled_at": { "type": "string", "format": "date-time" },
    "fingerprint": { "$ref": "#/$defs/fingerprint" }
  },
  "$defs": {
    "fingerprint": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "boundedId": { "type": "string", "minLength": 1, "maxLength": 256 },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "pattern": "^(?!(?:[\\s\\S]*\/)?(?:[Cc][Oo][Nn]|[Pp][Rr][Nn]|[Aa][Uu][Xx]|[Nn][Uu][Ll]|[Cc][Oo][Mm][1-9]|[Ll][Pp][Tt][1-9])(?:\\.[^\/]*)?(?:\/|$))(?![\\s\\S]*(?:^|\/)\\.{1,2}(?:\/|$))(?![\\s\\S]*(?:^|\/)[^\/]*[. ](?:\/|$))(?![\\s\\S]*[:\\\\])[^\\u0000\/]+(?:\/[^\\u0000\/]+)*$"
    },
    "mappingIdArray": { "type": "array", "maxItems": 64, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 512 } },
    "verifiedTestIdArray": { "type": "array", "maxItems": 256, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 512 } },
    "messageArray": { "type": "array", "maxItems": 256, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 1000 } },
    "pathArray": { "type": "array", "maxItems": 256, "uniqueItems": true, "items": { "$ref": "#/$defs/relativePath" } },
    "reasonCodeArray": {
      "type": "array",
      "maxItems": 256,
      "uniqueItems": true,
      "items": {
        "enum": [
          "CONTEXT_RECONCILIATION_DECISION_NOT_SUFFICIENT",
          "CONTEXT_RECONCILIATION_CHANGED_PATH_UNOWNED",
          "CONTEXT_RECONCILIATION_CHANGED_PATH_UNREPRESENTED",
          "CONTEXT_RECONCILIATION_CRITICAL_TEST_MISSING",
          "CONTEXT_RECONCILIATION_UNEXPECTED_PUBLIC_CONTRACT",
          "CONTEXT_RECONCILIATION_UNEXPECTED_DEPENDENCY",
          "CONTEXT_RECONCILIATION_UNEXPECTED_SIDE_EFFECT",
          "CONTEXT_RECONCILIATION_UNRELATED_WRITE",
          "CONTEXT_RECONCILIATION_REVIEWER_EVIDENCE_MISSING",
          "CONTEXT_RECONCILIATION_REVIEWER_EVIDENCE_STALE",
          "CONTEXT_RECONCILIATION_EXTRACTOR_EVIDENCE_MISSING",
          "CONTEXT_RECONCILIATION_GRAPH_DELTA_MISSING",
          "CONTEXT_RECONCILIATION_GRAPH_DELTA_TRUNCATED",
          "CONTEXT_RECONCILIATION_EXTRACTOR_FACT_MISMATCH",
          "CONTEXT_RECONCILIATION_UNPLANNED_HIGH_IMPACT",
          "CONTEXT_RECONCILIATION_GRAPH_TRUST_REGRESSION",
          "CONTEXT_RECONCILIATION_FINAL_WORKSPACE_STALE"
        ]
      }
    },
    "changedPath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind", "ownership_ids", "context_subject_ids", "test_obligation_ids"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "kind": { "enum": ["source", "test", "schema", "config", "documentation", "fixture", "other"] },
        "ownership_ids": { "$ref": "#/$defs/mappingIdArray" },
        "context_subject_ids": { "$ref": "#/$defs/mappingIdArray" },
        "test_obligation_ids": { "$ref": "#/$defs/mappingIdArray" }
      }
    },
    "unplannedItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "severity", "path", "description", "disposition", "analysis_update_id"],
      "properties": {
        "id": { "type": "string", "pattern": "^UNPLANNED-[A-Za-z0-9._-]{0,117}[A-Za-z0-9_-]$" },
        "kind": { "enum": ["node", "edge", "contract", "side_effect", "dependency", "path", "coverage", "unknown", "exclusion", "boundary"] },
        "severity": { "enum": ["low", "medium", "high", "critical"] },
        "path": { "anyOf": [{ "$ref": "#/$defs/relativePath" }, { "type": "null" }] },
        "description": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "disposition": { "enum": ["planned_equivalent", "accepted_low_impact", "requires_reanalysis"] },
        "analysis_update_id": { "anyOf": [{ "type": "string", "minLength": 1, "maxLength": 512 }, { "type": "null" }] }
      }
    }
  }
}

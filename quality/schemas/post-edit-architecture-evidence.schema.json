{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Tah10n/opencode-harness/quality/schemas/post-edit-architecture-evidence.schema.json",
  "title": "Trusted post-edit architecture evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_id",
    "producer",
    "mechanism_kind",
    "extractor_identity",
    "evaluator_identity",
    "command_receipt_fingerprint",
    "extractor_output_fingerprint",
    "policy_fingerprint",
    "final_workspace_fingerprint",
    "extracted_graph_fingerprint",
    "planned_graph_fingerprint",
    "graph_delta",
    "architecture_evaluation",
    "completed_at",
    "fingerprint"
  ],
  "properties": {
    "schema_version": { "const": 3 },
    "evidence_id": { "$ref": "#/$defs/safe_id" },
    "producer": { "const": "opencode-harness/post-edit-architecture-v3" },
    "mechanism_kind": { "enum": ["project_check", "runner_owned_extractor"] },
    "extractor_identity": { "$ref": "#/$defs/extractor_identity" },
    "evaluator_identity": { "$ref": "#/$defs/evaluator_identity" },
    "command_receipt_fingerprint": {
      "anyOf": [{ "$ref": "#/$defs/fingerprint" }, { "type": "null" }]
    },
    "extractor_output_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "policy_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "final_workspace_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "extracted_graph_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "planned_graph_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "graph_delta": { "$ref": "#/$defs/graph_delta" },
    "architecture_evaluation": { "$ref": "architecture-evaluation.schema.json" },
    "completed_at": { "type": "string", "format": "date-time" },
    "fingerprint": { "$ref": "#/$defs/fingerprint" }
  },
  "allOf": [
    {
      "if": { "properties": { "mechanism_kind": { "const": "project_check" } } },
      "then": { "properties": { "command_receipt_fingerprint": { "$ref": "#/$defs/fingerprint" } } },
      "else": { "properties": { "command_receipt_fingerprint": { "type": "null" } } }
    }
  ],
  "$defs": {
    "fingerprint": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "safe_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "trust_regression_id": {
      "type": "string",
      "pattern": "^TRUSTREG-[A-Za-z0-9._-]{0,118}[A-Za-z0-9_-]$"
    },
    "unplanned_item_id": {
      "type": "string",
      "pattern": "^UNPLANNED-[A-Za-z0-9._-]{0,117}[A-Za-z0-9_-]$"
    },
    "path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*//)[^:]+$"
    },
    "extractor_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer", "mechanism_id", "implementation_fingerprint"],
      "properties": {
        "producer": { "type": "string", "minLength": 1, "maxLength": 256 },
        "mechanism_id": { "$ref": "#/$defs/safe_id" },
        "implementation_fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "evaluator_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer", "algorithm_ids", "implementation_fingerprint"],
      "properties": {
        "producer": { "type": "string", "minLength": 1, "maxLength": 256 },
        "algorithm_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/safe_id" }
        },
        "implementation_fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "delta_signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signature", "count"],
      "properties": {
        "signature": { "$ref": "#/$defs/fingerprint" },
        "count": { "type": "integer", "minimum": 1, "maximum": 4096 }
      }
    },
    "delta_signatures": {
      "type": "array",
      "maxItems": 128,
      "items": { "$ref": "#/$defs/delta_signature" }
    },
    "bounded_unique_strings": {
      "type": "array",
      "maxItems": 128,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 1000 }
    },
    "trust_regression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "subject", "path", "before", "after", "description"],
      "properties": {
        "id": { "$ref": "#/$defs/trust_regression_id" },
        "kind": {
          "enum": [
            "coverage_regression",
            "confidence_regression",
            "unknown_added",
            "exclusion_added",
            "boundary_loss",
            "critical_path_downgrade"
          ]
        },
        "subject": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "path": { "anyOf": [{ "$ref": "#/$defs/path" }, { "type": "null" }] },
        "before": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "after": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "description": { "type": "string", "minLength": 1, "maxLength": 2000 }
      }
    },
    "unplanned_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "severity", "path", "description", "disposition", "analysis_update_id"],
      "properties": {
        "id": { "$ref": "#/$defs/unplanned_item_id" },
        "kind": {
          "enum": [
            "node",
            "edge",
            "contract",
            "side_effect",
            "dependency",
            "path",
            "coverage",
            "unknown",
            "exclusion",
            "boundary"
          ]
        },
        "severity": { "enum": ["medium", "high", "critical"] },
        "path": { "anyOf": [{ "$ref": "#/$defs/path" }, { "type": "null" }] },
        "description": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "disposition": { "const": "requires_reanalysis" },
        "analysis_update_id": { "type": "null" }
      }
    },
    "delta_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "added_nodes",
        "removed_nodes",
        "added_edges",
        "removed_edges",
        "added_affected_paths",
        "removed_affected_paths",
        "trust_regressions"
      ],
      "properties": {
        "added_nodes": { "$ref": "#/$defs/delta_count" },
        "removed_nodes": { "$ref": "#/$defs/delta_count" },
        "added_edges": { "$ref": "#/$defs/delta_count" },
        "removed_edges": { "$ref": "#/$defs/delta_count" },
        "added_affected_paths": { "$ref": "#/$defs/delta_count" },
        "removed_affected_paths": { "$ref": "#/$defs/delta_count" },
        "trust_regressions": { "$ref": "#/$defs/delta_count" }
      }
    },
    "delta_count": { "type": "integer", "minimum": 0, "maximum": 4096 },
    "graph_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "planned_graph_fingerprint",
        "final_graph_fingerprint",
        "added_nodes",
        "removed_nodes",
        "added_edges",
        "removed_edges",
        "added_affected_paths",
        "removed_affected_paths",
        "unexpected_public_contracts",
        "unexpected_dependency_directions",
        "unexpected_side_effect_edges",
        "trust_regressions",
        "unplanned_items",
        "counts",
        "truncated",
        "fingerprint"
      ],
      "properties": {
        "schema_version": { "const": 2 },
        "planned_graph_fingerprint": { "$ref": "#/$defs/fingerprint" },
        "final_graph_fingerprint": { "$ref": "#/$defs/fingerprint" },
        "added_nodes": { "$ref": "#/$defs/delta_signatures" },
        "removed_nodes": { "$ref": "#/$defs/delta_signatures" },
        "added_edges": { "$ref": "#/$defs/delta_signatures" },
        "removed_edges": { "$ref": "#/$defs/delta_signatures" },
        "added_affected_paths": { "$ref": "#/$defs/delta_signatures" },
        "removed_affected_paths": { "$ref": "#/$defs/delta_signatures" },
        "unexpected_public_contracts": { "$ref": "#/$defs/bounded_unique_strings" },
        "unexpected_dependency_directions": { "$ref": "#/$defs/bounded_unique_strings" },
        "unexpected_side_effect_edges": { "$ref": "#/$defs/bounded_unique_strings" },
        "trust_regressions": {
          "type": "array",
          "maxItems": 128,
          "items": { "$ref": "#/$defs/trust_regression" }
        },
        "unplanned_items": {
          "type": "array",
          "maxItems": 128,
          "items": { "$ref": "#/$defs/unplanned_item" }
        },
        "counts": { "$ref": "#/$defs/delta_counts" },
        "truncated": { "type": "boolean" },
        "fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    }
  }
}

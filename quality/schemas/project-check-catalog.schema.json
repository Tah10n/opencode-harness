{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Tah10n/opencode-harness/quality/schemas/project-check-catalog.schema.json",
  "title": "OpenCode Harness Project Check Catalog",
  "$comment": "Structural JSON Schema plus the normative runtime validator in lib/quality/project-check-catalog.mjs. The runtime additionally enforces UTF-8 byte and NUL limits, unique check_id values, executable basename restrictions, and interpreter eval denial that JSON Schema cannot express portably.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "catalog_id", "checks"],
  "properties": {
    "schema_version": { "const": 1 },
    "catalog_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "standard_lite_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_ownership_prefixes", "protected_paths"],
      "properties": {
        "allowed_ownership_prefixes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 1000 }
        },
        "protected_paths": {
          "type": "array",
          "maxItems": 128,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 1000 }
        }
      }
    },
    "checks": {
      "type": "array",
      "$comment": "check_id uniqueness is enforced by the normative runtime validator.",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check_id", "argv", "cwd", "phases", "timeout_ms", "max_output_chars"],
        "properties": {
          "check_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" },
          "argv": {
            "type": "array",
            "$comment": "The runtime validator rejects shell interpreters, npx/npm exec, and source-text eval flags before execution.",
            "minItems": 1,
            "maxItems": 64,
            "prefixItems": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 4096,
                "pattern": "^(?!\\s*$)(?!.*\\u0000).+$"
              }
            ],
            "items": { "type": "string", "maxLength": 4096, "pattern": "^(?!.*\\u0000).*$" }
          },
          "cwd": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000,
            "pattern": "^(?![A-Za-z]:)(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$))(?!.*\\u0000).+$"
          },
          "phases": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "uniqueItems": true,
            "items": { "enum": ["preimplementation", "slice", "integration"] }
          },
          "timeout_ms": { "type": "integer", "minimum": 1, "maximum": 600000 },
          "max_output_chars": { "type": "integer", "minimum": 1, "maximum": 4194304 }
        }
      }
    }
  }
}

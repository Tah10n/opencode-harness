{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Top-level interchange schema. Cross-field mappings, bounds, references, privacy, and fingerprints are enforced by lib/quality/dossier.mjs and verified by scripts/verify-quality-contracts.mjs.",
  "title": "OpenCode Harness Engineering Dossier v1",
  "type": "object",
  "required": [
    "schema_version",
    "dossier_id",
    "run_id",
    "task_id",
    "risk_class",
    "mode",
    "task_type",
    "user_visible_goal",
    "revision",
    "status",
    "task_shape",
    "behavior_contract",
    "compatibility_contract",
    "public_contracts",
    "system_boundaries",
    "affected_areas",
    "entry_points",
    "call_paths",
    "data_shapes",
    "invariants",
    "edge_cases",
    "failure_modes",
    "premortem_matrix",
    "counterexamples",
    "test_obligations",
    "specialized_checks",
    "assumptions",
    "unknowns",
    "subagent_handoffs",
    "implementation_slices",
    "impact_graph",
    "architecture_assessment",
    "context_coverage",
    "verification_plan",
    "rollback_recovery",
    "plan_challenge",
    "gate_state",
    "verification_boundary",
    "created_at",
    "updated_at",
    "finalized_at",
    "fingerprint"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "dossier_id": { "$ref": "#/$defs/id" },
    "run_id": { "$ref": "#/$defs/id" },
    "task_id": { "$ref": "#/$defs/id" },
    "risk_class": { "enum": ["standard-lite", "high", "critical"] },
    "mode": { "enum": ["standard-lite", "full"] },
    "task_type": { "enum": ["bug_fix", "diagnosis_driven_implementation", "behavior_preserving_refactor", "new_feature", "migration", "security", "maintenance"] },
    "user_visible_goal": { "type": "string", "minLength": 1 },
    "revision": { "type": "integer", "minimum": 1 },
    "status": { "enum": ["draft", "finalized"] },
    "task_shape": { "type": "object" },
    "behavior_contract": { "type": "object" },
    "compatibility_contract": { "type": "object" },
    "public_contracts": { "type": "array", "maxItems": 128 },
    "system_boundaries": { "type": "array", "maxItems": 128 },
    "affected_areas": { "type": "array", "maxItems": 128 },
    "entry_points": { "type": "array", "maxItems": 128 },
    "call_paths": { "type": "array", "maxItems": 128 },
    "data_shapes": { "type": "array", "maxItems": 128 },
    "invariants": { "type": "array", "maxItems": 128 },
    "edge_cases": { "type": "array", "maxItems": 128 },
    "failure_modes": { "type": "array", "maxItems": 128 },
    "premortem_matrix": { "type": "array", "maxItems": 128 },
    "counterexamples": { "type": "array", "maxItems": 128 },
    "test_obligations": { "type": "array", "maxItems": 128 },
    "specialized_checks": { "type": "array", "maxItems": 128 },
    "assumptions": { "type": "array", "maxItems": 128 },
    "unknowns": {
      "type": "array",
      "maxItems": 128,
      "items": { "$ref": "#/$defs/unknown" }
    },
    "subagent_handoffs": { "type": "array", "maxItems": 128 },
    "implementation_slices": { "type": "array", "maxItems": 128 },
    "impact_graph": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "engineering-impact-graph.schema.json" }
      ]
    },
    "architecture_assessment": { "type": "object" },
    "context_coverage": { "type": "object" },
    "verification_plan": { "type": "object" },
    "rollback_recovery": { "type": "object" },
    "plan_challenge": { "type": "object" },
    "gate_state": { "type": "object" },
    "verification_boundary": { "type": "object" },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "updated_at": { "$ref": "#/$defs/timestamp" },
    "finalized_at": { "type": ["string", "null"], "format": "date-time" },
    "fingerprint": { "type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "unknown": {
      "type": "object",
      "required": ["id", "scope_ids", "statement", "impact", "resolution_plan", "owner", "blocking"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "scope_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "statement": { "type": "string", "minLength": 1 },
        "impact": { "type": "string", "minLength": 1 },
        "resolution_plan": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1, "maxLength": 256 },
        "blocking": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
